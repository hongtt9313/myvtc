{
  "version": 2,
  "buildCommand": "python3 build.py",
  "outputDirectory": "dist",
  "cleanUrls": false,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/index",
      "destination": "/index.html"
    },
    {
      "source": "/MyVTC_Home",
      "destination": "/MyVTC_Home.html"
    },
    {
      "source": "/MobileApp",
      "destination": "/MobileApp.html"
    },
    {
      "source": "/MyAccount",
      "destination": "/MyAccount.html"
    },
    {
      "source": "/Loyalty",
      "destination": "/Loyalty.html"
    },
    {
      "source": "/Service",
      "destination": "/Service.html"
    },
    {
      "source": "/Shop",
      "destination": "/Shop.html"
    },
    {
      "source": "/RechargeDetail",
      "destination": "/RechargeDetail.html"
    },
    {
      "source": "/Support",
      "destination": "/Support.html"
    },
    {
      "source": "/CMS",
      "destination": "/CMS.html"
    }
  ]
}
